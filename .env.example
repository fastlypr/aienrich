# AI Enrich — local environment file.
# Copy this file to .env and fill in your real values.
# .env is gitignored, so secrets stay on your machine.

# === Required for the agent runner ============================================

# NVIDIA NIM API key — get one at https://build.nvidia.com (free tier works).
NVIDIA_API_KEY=nvapi-REPLACE_ME

# Apify API token — get one at https://console.apify.com.
# Leave blank or comment out to run the agent without Apify
# (it will still extract name/company/category but skip LinkedIn/Instagram).
APIFY_TOKEN=apify_api_REPLACE_ME

# === Optional ================================================================

# Override the NVIDIA model. Default is openai/gpt-oss-120b.
# NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# === Existing config (also accepted, but normally lives in .aienrich_config.json) ===

# NOTION_TOKEN=ntn_...
# NOTION_DB_ID=...
# AIENRICH_SHEET_URL=https://docs.google.com/spreadsheets/d/.../edit
